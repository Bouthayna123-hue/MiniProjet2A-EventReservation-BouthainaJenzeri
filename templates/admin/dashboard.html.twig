{% extends 'base.html.twig' %}
{% block title %}Admin Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --green-dark: #0f1f15; --green-mid: #1a3122;
            --green-accent: #4caf73; --green-border: #2d5240;
            --green-muted: #5a8a6a; --green-text: #a8dbb8;
        }
        .page-wrap { min-height:100vh; background:#f5f4f0; padding:2rem; font-family:'DM Sans',sans-serif; }
        .page-inner { max-width:1000px; margin:0 auto; }

        /* ── Top header ── */
        .dash-header { background:var(--green-dark); border-radius:14px; padding:1.5rem 2rem; margin-bottom:1.5rem; display:flex; align-items:center; justify-content:space-between; }
        .dash-title { font-family:'Lora',serif; font-size:22px; color:#e0f0e5; }
        .dash-bar { width:24px; height:2px; background:var(--green-accent); margin-top:6px; }
        .dash-user { font-size:13px; color:var(--green-muted); }

        /* ── Stat cards ── */
        .stats-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:1.5rem; }
        .stat-card { background:#fff; border-radius:12px; padding:1.25rem 1.5rem; border:1px solid #ebebе7; }
        .stat-label { font-size:11px; font-weight:500; letter-spacing:.05em; text-transform:uppercase; color:#aaa; margin-bottom:6px; }
        .stat-value { font-family:'Lora',serif; font-size:32px; color:#111; }
        .stat-link { display:block; margin-top:.75rem; font-size:12px; color:var(--green-accent); text-decoration:none; font-weight:500; }
        .stat-link:hover { opacity:.75; }

        /* ── Quick actions ── */
        .section-title { font-family:'Lora',serif; font-size:16px; color:#111; margin-bottom:1rem; }
        .actions-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1rem; margin-bottom:1.5rem; }
        .action-card { background:#fff; border-radius:12px; padding:1.25rem 1.5rem; border:1px solid #ebebе7; text-decoration:none; display:flex; align-items:center; justify-content:space-between; transition:border-color .15s; }
        .action-card:hover { border-color:var(--green-accent); }
        .action-card-label { font-size:14px; font-weight:500; color:#111; }
        .action-card-sub { font-size:12px; color:#aaa; margin-top:3px; }
        .action-arrow { font-size:18px; color:var(--green-accent); }

        /* ── Recent reservations ── */
        .section-card { background:#fff; border-radius:12px; border:1px solid #ebebе7; overflow:hidden; }
        .section-card-header { padding:1rem 1.5rem; border-bottom:1px solid #f0f0ec; display:flex; align-items:center; justify-content:space-between; }
        .section-card-header span { font-size:13px; font-weight:500; color:#111; }
        .section-card-header a { font-size:12px; color:var(--green-accent); text-decoration:none; font-weight:500; }
        table { width:100%; border-collapse:collapse; font-size:13px; }
        th { padding:8px 16px; text-align:left; font-size:11px; font-weight:500; letter-spacing:.05em; text-transform:uppercase; color:#aaa; border-bottom:1px solid #f0f0ec; }
        td { padding:11px 16px; color:#222; border-bottom:1px solid #f8f8f6; }
        tbody tr:last-child td { border-bottom:none; }
        .ev-badge { display:inline-block; padding:3px 9px; border-radius:20px; font-size:11px; font-weight:500; background:#e1f5ee; color:#0f6e56; }
    </style>
{% endblock %}

{% block body %}
<div class="page-wrap">
    <div class="page-inner">

        <div class="dash-header">
            <div>
                <div class="dash-title">Admin dashboard</div>
                <div class="dash-bar"></div>
            </div>
            <span class="dash-user">{{ app.user.userIdentifier }}</span>
        </div>

        {# ── Stats ── #}
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Total events</div>
                <div class="stat-value">{{ totalEvents }}</div>
                <a class="stat-link" href="{{ path('app_event_crud_index') }}">Manage events →</a>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total reservations</div>
                <div class="stat-value">{{ totalReservations }}</div>
                <a class="stat-link" href="{{ path('app_reservation_index') }}">View all →</a>
            </div>
            <div class="stat-card">
                <div class="stat-label">Logged in as</div>
                <div style="font-size:15px;font-weight:500;color:#111;margin-top:6px">{{ app.user.userIdentifier }}</div>
                <a class="stat-link" href="{{ path('app_logout') }}">Sign out →</a>
            </div>
        </div>

        {# ── Quick actions ── #}
        <p class="section-title">Quick actions</p>
        <div class="actions-grid">
            <a class="action-card" href="{{ path('app_event_crud_new') }}">
                <div>
                    <div class="action-card-label">Add new event</div>
                    <div class="action-card-sub">Create an event for users to reserve</div>
                </div>
                <span class="action-arrow">→</span>
            </a>
            <a class="action-card" href="{{ path('app_event_crud_index') }}">
                <div>
                    <div class="action-card-label">Manage events</div>
                    <div class="action-card-sub">Edit, view or delete existing events</div>
                </div>
                <span class="action-arrow">→</span>
            </a>
            <a class="action-card" href="{{ path('app_reservation_index') }}">
                <div>
                    <div class="action-card-label">All reservations</div>
                    <div class="action-card-sub">Browse and manage reservations</div>
                </div>
                <span class="action-arrow">→</span>
            </a>
            <a class="action-card" href="{{ path('app_event_crud_index') }}">
                <div>
                    <div class="action-card-label">View public listing</div>
                    <div class="action-card-sub">See what users see</div>
                </div>
                <span class="action-arrow">→</span>
            </a>
        </div>

        {# ── Recent reservations ── #}
        <p class="section-title">Recent reservations</p>
        <div class="section-card">
            <div class="section-card-header">
                <span>Last 5 reservations</span>
                <a href="{{ path('app_reservation_index') }}">View all</a>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Event</th>
                        <th>Email</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in recentReservations %}
                    <tr>
                        <td>{{ r.name }}</td>
                        <td><span class="ev-badge">{{ r.event.title }}</span></td>
                        <td>{{ r.email }}</td>
                        <td>{{ r.createdAt ? r.createdAt|date('d M Y H:i') : '—' }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="4" style="text-align:center;color:#aaa;padding:2rem">No reservations yet.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

    </div>
</div>
{% endblock %}
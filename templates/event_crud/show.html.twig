{% extends 'base.html.twig' %}

{% block title %}Event Details{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
        :root {
            --green-dark:   #0f1f15;
            --green-mid:    #1a3122;
            --green-accent: #4caf73;
            --green-border: #2d5240;
            --green-text:   #a8dbb8;
        }

        .page-wrap {
            min-height: 100vh;
            background: #f5f4f0;
            padding: 2rem;
            font-family: 'DM Sans', sans-serif;
        }

        .page-inner {
            max-width: 800px;
            margin: 0 auto;
        }

        .card {
            background: #fff;
            border-radius: 14px;
            padding: 2rem;
            box-shadow: 0 2px 12px rgba(0,0,0,0.05);
            border: 1px solid #ebebe7;
        }

        .title {
            font-family: 'Lora', serif;
            font-size: 28px;
            margin-bottom: 1rem;
            color: #111;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .admin-badge {
            background: var(--green-mid);
            color: var(--green-text);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .user-badge {
            background: #4a6fa5;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .event-detail {
            margin: 1.5rem 0;
        }

        .detail-row {
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #eee;
        }

        .detail-label {
            font-size: 13px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }

        .detail-value {
            font-size: 16px;
            color: #333;
            font-weight: 500;
        }

        .description-text {
            line-height: 1.6;
            color: #555;
        }

        .btn {
            background: var(--green-mid);
            color: var(--green-text);
            border: 1px solid var(--green-border);
            border-radius: 8px;
            padding: 10px 18px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: .15s;
            text-decoration: none;
            display: inline-block;
        }

        .btn:hover {
            background: var(--green-accent);
            color: var(--green-dark);
            border-color: var(--green-accent);
        }

        .btn-reserve {
            background: var(--green-accent);
            color: var(--green-dark);
            margin-right: 10px;
        }

        .btn-reserve:hover {
            background: var(--green-mid);
            color: var(--green-text);
        }

        .btn-edit {
            background: #4a6fa5;
            color: white;
            border-color: #3a5a8a;
        }

        .btn-edit:hover {
            background: #3a5a8a;
            color: white;
        }

        .btn-delete {
            background: #a54444;
            color: white;
            border-color: #8a3a3a;
        }

        .btn-delete:hover {
            background: #8a3a3a;
            color: white;
        }

        .action-buttons {
            margin-top: 2rem;
            display: flex;
            gap: 1rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .back-link {
            display: inline-block;
            margin-top: 1rem;
            font-size: 13px;
            color: #888;
            text-decoration: none;
        }

        .back-link:hover {
            color: #4caf73;
        }

        .seats-available {
            color: var(--green-mid);
            font-weight: bold;
        }

        .delete-form {
            display: inline-block;
        }
    </style>
{% endblock %}

{% block body %}
<div class="page-wrap">
    <div class="page-inner">

        <div class="card">
            <div class="title">
                <span>{{ event.title }}</span>
                {% if is_granted('ROLE_ADMIN') %}
                    <span class="admin-badge">👑 Admin View</span>
                {% else %}
                    <span class="user-badge">👤 User View</span>
                {% endif %}
            </div>

            <div class="event-detail">
                <div class="detail-row">
                    <div class="detail-label">Date & Time</div>
                    <div class="detail-value">📅 {{ event.date|date('l, F j, Y H:i') }}</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">Location</div>
                    <div class="detail-value">📍 {{ event.location }}</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">Available Seats</div>
                    <div class="detail-value seats-available">🪑 {{ event.seats }} seats remaining</div>
                </div>

                {% if event.description %}
                    <div class="detail-row">
                        <div class="detail-label">Description</div>
                        <div class="detail-value description-text">{{ event.description|nl2br }}</div>
                    </div>
                {% endif %}

                {% if event.image %}
                    <div class="detail-row">
                        <div class="detail-label">Event Image</div>
                        <div class="detail-value">
                            <img src="{{ asset('uploads/events/' ~ event.image) }}" 
                                 alt="{{ event.title }}" 
                                 style="max-width: 100%; border-radius: 8px; margin-top: 10px;">
                        </div>
                    </div>
                {% endif %}
            </div>

            <div class="action-buttons">
                {# Reservation button - only for non-admin users (ROLE_USER) #}
                {% if is_granted('ROLE_USER') and not is_granted('ROLE_ADMIN') %}
                    <a class="btn btn-reserve" href="{{ path('app_reservation_new', {'id': event.id}) }}">
                        🎫 Reserve a Seat
                    </a>
                {% endif %}
                
                {# Admin actions - only for ROLE_ADMIN #}
                {% if is_granted('ROLE_ADMIN') %}
                    <a class="btn btn-edit" href="{{ path('app_event_crud_edit', {'id': event.id}) }}">
                        ✏️ Edit Event
                    </a>
                    <form method="post" action="{{ path('app_event_crud_delete', {'id': event.id}) }}" 
                          onsubmit="return confirm('⚠️ Are you sure you want to delete this event?\nThis action will also delete all associated reservations and cannot be undone.');" 
                          class="delete-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                        <button type="submit" class="btn btn-delete">🗑️ Delete Event</button>
                    </form>
                {% endif %}
            </div>

            <a class="back-link" href="{{ path('app_event_crud_index') }}">
                ← Back to events list
            </a>
        </div>

    </div>
</div>
{% endblock %}
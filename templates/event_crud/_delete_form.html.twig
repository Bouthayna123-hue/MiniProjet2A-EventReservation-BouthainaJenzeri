<form method="post" action="{{ path('app_event_crud_delete', {'id': event.id}) }}" 
      onsubmit="return confirm('⚠️ Are you sure you want to delete this event?\nThis action will also delete all associated reservations and cannot be undone.');"
      style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
    <button type="submit" class="btn btn-delete">🗑️ Delete Event</button>
</form>
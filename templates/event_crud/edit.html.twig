{% extends 'base.html.twig' %}

{% block title %}Edit Event{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <style>
        :root {
            --green-dark:   #0f1f15;
            --green-mid:    #1a3122;
            --green-accent: #4caf73;
            --green-border: #2d5240;
            --green-text:   #a8dbb8;
        }

        .page-wrap {
            min-height: 100vh;
            background: #f5f4f0;
            padding: 2rem;
            font-family: 'DM Sans', sans-serif;
        }

        .page-inner {
            max-width: 700px;
            margin: 0 auto;
        }

        .card {
            background: #fff;
            border-radius: 14px;
            padding: 2rem;
            box-shadow: 0 2px 12px rgba(0,0,0,0.05);
            border: 1px solid #ebebe7;
        }

        .title {
            font-family: 'Lora', serif;
            font-size: 22px;
            margin-bottom: 1.5rem;
            color: #111;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .admin-badge {
            background: var(--green-mid);
            color: var(--green-text);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            font-size: 13px;
            color: #555;
            display: block;
            margin-bottom: 5px;
            font-weight: 500;
        }

        input, textarea, select {
            width: 100%;
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            transition: border-color 0.15s;
        }

        input:focus, textarea:focus, select:focus {
            border-color: var(--green-accent);
            outline: none;
            box-shadow: 0 0 0 2px rgba(76, 175, 115, 0.1);
        }

        .btn {
            background: var(--green-mid);
            color: var(--green-text);
            border: 1px solid var(--green-border);
            border-radius: 8px;
            padding: 10px 18px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: .15s;
            text-decoration: none;
            display: inline-block;
        }

        .btn:hover {
            background: var(--green-accent);
            color: var(--green-dark);
            border-color: var(--green-accent);
        }

        .btn-update {
            background: var(--green-accent);
            color: var(--green-dark);
            margin-right: 10px;
        }

        .btn-update:hover {
            background: var(--green-mid);
            color: var(--green-text);
        }

        .btn-delete {
            background: #a54444;
            color: white;
            border-color: #8a3a3a;
        }

        .btn-delete:hover {
            background: #8a3a3a;
            color: white;
        }

        .action-buttons {
            margin-top: 2rem;
            display: flex;
            gap: 1rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .back-link {
            display: inline-block;
            margin-top: 1rem;
            font-size: 13px;
            color: #888;
            text-decoration: none;
        }

        .back-link:hover {
            color: #4caf73;
        }

        .delete-form {
            display: inline-block;
        }

        .current-image {
            margin-top: 0.5rem;
            padding: 1rem;
            background: #f9f9f9;
            border-radius: 8px;
            border: 1px solid #eee;
        }

        .current-image img {
            max-width: 200px;
            border-radius: 6px;
            margin-top: 0.5rem;
        }

        .current-image p {
            margin: 0;
            font-size: 12px;
            color: #666;
        }

        hr {
            margin: 1rem 0;
            border: none;
            border-top: 1px solid #eee;
        }
    </style>
{% endblock %}

{% block body %}
<div class="page-wrap">
    <div class="page-inner">
        <div class="card">
            <div class="title">
                <span>✏️ Edit Event</span>
                <span class="admin-badge">👑 Admin Mode</span>
            </div>
{{ form_start(form, {'attr': {'data-turbo': 'false'}}) }}
    
    <div class="form-group">
        {{ form_label(form.title) }}
        {{ form_widget(form.title) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="form-group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {'attr': {'rows': 5}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-group">
        {{ form_label(form.date) }}
        {{ form_widget(form.date) }}
        {{ form_errors(form.date) }}
    </div>

    <div class="form-group">
        {{ form_label(form.location) }}
        {{ form_widget(form.location) }}
        {{ form_errors(form.location) }}
    </div>

    <div class="form-group">
        {{ form_label(form.seats) }}
        {{ form_widget(form.seats, {'attr': {'min': 1}}) }}
        {{ form_errors(form.seats) }}
    </div>

    <div class="form-group">
        {{ form_label(form.image) }}
        {{ form_widget(form.image) }}
        {{ form_errors(form.image) }}
        {% if event.image %}
            <div class="current-image">
                <p>Current image:</p>
                <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}">
                <p>Upload a new image to replace this one.</p>
            </div>
        {% endif %}
    </div>

   <div style="margin-top:2rem; display:flex; gap:1rem; align-items:center; flex-wrap:wrap">
        <button type="submit" class="btn btn-update">Update Event</button>
    </div>

{{ form_end(form) }}

<div style="margin-top:1rem; display:flex; gap:1rem; align-items:center; flex-wrap:wrap">
    <form method="post"
          action="{{ path('app_event_crud_delete', {'id': event.id}) }}"
          onsubmit="return confirm('Are you sure you want to delete this event?')"
          style="display:inline-block">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
        <button type="submit" class="btn btn-delete">Delete Event</button>
    </form>

    <a class="back-link" href="{{ path('app_event_crud_index') }}" style="margin-top:0">← Back to events list</a>
</div>
    </div>
</div>
{% endblock %}
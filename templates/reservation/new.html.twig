{% extends 'base.html.twig' %}
{% block title %}New Reservation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --green-dark:   #0f1f15;
            --green-mid:    #1a3122;
            --green-accent: #4caf73;
            --green-border: #2d5240;
            --green-muted:  #5a8a6a;
            --green-text:   #a8dbb8;
        }

        .page-wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f4f0;
            padding: 2rem;
            font-family: 'DM Sans', sans-serif;
        }

        .res-card {
            display: flex;
            width: 100%;
            max-width: 720px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 40px rgba(0,0,0,0.10);
        }

        /* ── Side panel ── */
        .res-side {
            width: 240px;
            flex-shrink: 0;
            background: var(--green-dark);
            padding: 2.5rem 1.75rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .res-logo {
            font-family: 'Lora', serif;
            font-size: 22px;
            color: #e0f0e5;
            letter-spacing: -0.5px;
        }
        .res-logo-bar { width: 24px; height: 2px; background: var(--green-accent); margin-top: 8px; }

        .res-event-box {
            background: #1a3122;
            border: 0.5px solid #2d5240;
            border-radius: 10px;
            padding: 1rem;
        }
        .res-event-label {
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--green-muted);
            margin-bottom: 6px;
        }
        .res-event-title {
            font-family: 'Lora', serif;
            font-size: 15px;
            color: #e0f0e5;
            line-height: 1.35;
            margin-bottom: 8px;
        }
        .res-event-meta { font-size: 11px; color: var(--green-muted); line-height: 1.7; }
        .res-event-seats {
            display: inline-block;
            margin-top: 8px;
            font-size: 11px;
            font-weight: 500;
            background: #0f6e56;
            color: #9fe1cb;
            padding: 3px 10px;
            border-radius: 20px;
        }

        .res-dots { display: flex; gap: 6px; }
        .res-dot { width: 6px; height: 6px; border-radius: 50%; background: #2a4a32; }
        .res-dot.active { background: var(--green-accent); }

        /* ── Form panel ── */
        .res-main {
            flex: 1;
            background: #fff;
            padding: 2.5rem 2rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .res-heading {
            font-family: 'Lora', serif;
            font-size: 22px;
            font-weight: 500;
            color: #111;
            margin: 0 0 4px;
        }
        .res-sub { font-size: 13px; color: #888; margin: 0 0 1.75rem; }

        .form-group { margin-bottom: 1.1rem; }
        .form-group label {
            display: block;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 6px;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            box-sizing: border-box;
            border: 1px solid #e0e0dc;
            border-radius: 8px;
            padding: 9px 12px;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            background: #fafaf8;
            color: #111;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--green-accent);
            box-shadow: 0 0 0 3px rgba(76,175,115,.12);
        }
        .form-group input[disabled],
        .form-group select[disabled] {
            background: #f0f0ec;
            color: #aaa;
            cursor: not-allowed;
        }

        .btn-submit {
            width: 100%;
            padding: 10px;
            background: var(--green-mid);
            color: var(--green-text);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid var(--green-border);
            border-radius: 8px;
            cursor: pointer;
            letter-spacing: .02em;
            transition: background .15s, color .15s;
            margin-top: .5rem;
        }
        .btn-submit:hover {
            background: var(--green-accent);
            color: var(--green-dark);
            border-color: var(--green-accent);
        }

        .res-back {
            display: block;
            text-align: center;
            margin-top: .875rem;
            font-size: 12.5px;
            color: #aaa;
            text-decoration: none;
        }
        .res-back:hover { color: var(--green-accent); }

        @media (max-width: 580px) {
            .res-side { display: none; }
            .res-card { max-width: 400px; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="page-wrap">
    <div class="res-card">

        {# ── Side panel — shows event details ── #}
        <div class="res-side">
            <div>
                <div class="res-logo">EventReserve</div>
                <div class="res-logo-bar"></div>
            </div>

            <div class="res-event-box">
                <div class="res-event-label">You are reserving</div>
                <div class="res-event-title">{{ event.title }}</div>
                <div class="res-event-meta">
                    {% if event.date %}
                        {{ event.date|date('d M Y') }}<br>
                    {% endif %}
                    {% if event.location %}
                        {{ event.location }}
                    {% endif %}
                </div>
                {% if event.seats > 0 %}
                    <span class="res-event-seats">{{ event.seats }} seat{{ event.seats != 1 ? 's' : '' }} left</span>
                {% endif %}
            </div>

            <div class="res-dots">
                <div class="res-dot active"></div>
                <div class="res-dot"></div>
                <div class="res-dot"></div>
            </div>
        </div>

        {# ── Form panel ── #}
        <div class="res-main">
            <h1 class="res-heading">Reserve your spot</h1>
            <p class="res-sub">Fill in your details to confirm your reservation.</p>

            {{ include('reservation/_form.html.twig') }}

            <a href="{{ path('app_event_crud_index') }}" class="res-back">← Back to events</a>
        </div>

    </div>
</div>
{% endblock %}
{# templates/registration/register.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Create Account{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --green-dark: #0f1f15;
            --green-mid: #1a3122;
            --green-accent: #4caf73;
            --green-border: #2d5240;
            --green-muted: #5a8a6a;
            --green-text: #a8dbb8;
        }

        .register-wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f4f0;
            padding: 2rem;
            font-family: 'DM Sans', sans-serif;
        }

        .register-card {
            display: flex;
            width: 100%;
            max-width: 720px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 40px rgba(0,0,0,0.10);
        }

        /* ── Left panel ── */
        .register-side {
            width: 240px;
            flex-shrink: 0;
            background: var(--green-dark);
            padding: 2.5rem 1.75rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .register-logo {
            font-family: 'Lora', serif;
            font-size: 22px;
            color: #e0f0e5;
            letter-spacing: -0.5px;
        }
        .register-logo-bar {
            width: 24px; height: 2px;
            background: var(--green-accent);
            margin-top: 8px;
        }
        .register-tagline {
            font-size: 12px;
            color: var(--green-muted);
            line-height: 1.6;
        }
        .register-dots {
            display: flex;
            gap: 6px;
        }
        .register-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: #2a4a32;
        }
        .register-dot.active { background: var(--green-accent); }

        /* ── Right / form panel ── */
        .register-main {
            flex: 1;
            background: #fff;
            padding: 2.5rem 2rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .register-heading {
            font-family: 'Lora', serif;
            font-size: 24px;
            font-weight: 500;
            color: #111;
            margin: 0 0 4px;
        }
        .register-sub {
            font-size: 13px;
            color: #888;
            margin: 0 0 2rem;
        }

        /* ── Flash messages ── */
        .alert-danger {
            background: #fff0f0;
            border: 1px solid #f5c6c6;
            color: #a33;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            margin-bottom: 1.25rem;
        }

        /* ── Form rows ── */
        .form-group {
            margin-bottom: 1.1rem;
        }
        .form-group label {
            display: block;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 6px;
        }
        .form-group input[type="email"],
        .form-group input[type="password"],
        .form-group input[type="text"] {
            width: 100%;
            box-sizing: border-box;
            border: 1px solid #e0e0dc;
            border-radius: 8px;
            padding: 9px 12px;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            background: #fafaf8;
            color: #111;
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .form-group input:focus {
            border-color: var(--green-accent);
            box-shadow: 0 0 0 3px rgba(76,175,115,0.12);
        }

        /* ── Checkbox ── */
        .form-check {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 1.5rem;
        }
        .form-check input[type="checkbox"] {
            margin-top: 2px;
            accent-color: var(--green-accent);
            width: 15px; height: 15px;
            flex-shrink: 0;
            cursor: pointer;
        }
        .form-check label {
            font-size: 12.5px;
            color: #666;
            line-height: 1.5;
            cursor: pointer;
        }
        .form-check a { color: var(--green-accent); text-decoration: none; }

        /* ── Submit button ── */
        .btn-register {
            width: 100%;
            padding: 10px;
            background: var(--green-mid);
            color: var(--green-text);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 500;
            border: 1px solid var(--green-border);
            border-radius: 8px;
            cursor: pointer;
            letter-spacing: 0.02em;
            transition: background 0.15s, color 0.15s;
        }
        .btn-register:hover {
            background: var(--green-accent);
            color: var(--green-dark);
            border-color: var(--green-accent);
        }

        .register-login {
            text-align: center;
            margin-top: 1rem;
            font-size: 12.5px;
            color: #999;
        }
        .register-login a {
            color: var(--green-accent);
            text-decoration: none;
            font-weight: 500;
        }

        /* ── Responsive ── */
        @media (max-width: 580px) {
            .register-side { display: none; }
            .register-card { max-width: 400px; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="register-wrap">
    <div class="register-card">

        <div class="register-side">
            <div>
                <div class="register-logo">EventReserve</div>
                <div class="register-logo-bar"></div>
            </div>
            <p class="register-tagline">Create an account to start your journey with us.</p>
            <div class="register-dots">
                <div class="register-dot active"></div>
                <div class="register-dot"></div>
                <div class="register-dot"></div>
            </div>
        </div>

        <div class="register-main">
            {# ✅ Display flash messages #}
            {% for message in app.flashes('success') %}
                <div class="alert-success">
                    {{ message }}
                </div>
            {% endfor %}

            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="alert-danger">{{ flash_error }}</div>
            {% endfor %}

            <h1 class="register-heading">Create account</h1>
            <p class="register-sub">Fill in your details below to get started.</p>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, { attr: { novalidate: 'novalidate' } }) }}

                <div class="form-group">
                    {{ form_label(registrationForm.email) }}
                    {{ form_widget(registrationForm.email, { attr: { placeholder: 'you@example.com' } }) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group">
                    <label>Password</label>
                    {{ form_widget(registrationForm.plainPassword, { attr: { placeholder: 'Min. 8 characters' } }) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                <div class="form-check">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    {{ form_label(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="btn-register">Create account →</button>

            {{ form_end(registrationForm) }}

            <p class="register-login">
                Already have an account? <a href="{{ path('app_login') }}">Sign in</a>
            </p>
        </div>

    </div>
</div>
{% endblock %}